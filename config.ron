// GLASS Overlay configuration (RON format)
// Edit this file and save — watched apps can reload updated config snapshots automatically.
//
// Runtime behavior changes only when an app re-reads and reapplies the updated snapshot.
// glass-starter uses config.ron in the working directory by default and watches it,
// but the reference starter does not currently re-read/reapply watched config after startup.
// Library consumers can choose their own config path; ConfigStore::load(...) supports both .ron and .toml.
(
    position: (x: 20.0, y: 20.0),
    size: (width: 360.0, height: 60.0),
    opacity: 1.0,
    colors: (
        primary: (0.0, 0.0, 0.0, 0.6),     // semi-transparent black background
        secondary: (1.0, 1.0, 1.0, 1.0),   // opaque white text
    ),
    input: (
        hotkey_vk: 0x7B,                   // F12 — toggle interactive mode
        hotkey_modifiers: 0,                // no modifier (0=none, 1=Alt, 2=Ctrl, 4=Shift, 8=Win)
        interactive_timeout_ms: 4000,       // revert to passive after 4 seconds
        show_indicator: true,               // stored indicator flag; not currently applied by the reference starter runtime
    ),
    // ── Module system ──────────────────────────────────────────────────────
    // Enable or disable individual HUD modules and configure their behaviour.
    modules: (
        clock_enabled: true,                // show the clock widget
        clock_format: "%H:%M:%S",           // strftime-compatible format string
        system_stats_enabled: true,         // show CPU + memory usage widget
        stats_interval_ms: 2000,            // system stats refresh interval (ms)
        fps_enabled: true,                  // show overlay-only FPS counter widget
    ),
    // ── Layout system ──────────────────────────────────────────────────────
    // Anchor-based positioning for each widget.
    // Anchors: TopLeft | TopRight | BottomLeft | BottomRight | Center | ScreenPercentage(x, y)
    // margin_x/margin_y: pixel offset inward from the anchor edge.
    layout: (
        clock: (
            anchor: TopLeft,                // clock anchored to top-left corner
            margin_x: 10.0,                 // 10 px from the left edge
            margin_y: 10.0,                 // 10 px from the top edge
        ),
        system_stats: (
            anchor: TopLeft,                // stats stacked below the clock
            margin_x: 10.0,
            margin_y: 34.0,                 // ~one line below clock (24 px font + gap)
        ),
        fps: (
            anchor: TopLeft,                // FPS counter stacked below stats
            margin_x: 10.0,
            margin_y: 60.0,                 // ~two lines below clock
        ),
    ),
)
